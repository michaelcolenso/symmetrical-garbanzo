# KPF Environment Configuration
# Copy to .env and fill in values

# Workspace base directory (default: ./workspaces)
KPF_WORKSPACE_BASE=./workspaces

# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
KPF_LOG_LEVEL=INFO

# Anthropic API key (required from M4 onward, optional in M1)
ANTHROPIC_API_KEY=

# Evidence gate thresholds
# KPF_GATE_MIN_SOURCES=15
# KPF_GATE_MIN_PAIN_QUOTES=5
# KPF_GATE_MIN_SPEND_SIGNALS=3
# KPF_GATE_MIN_COMPETITORS=3
# KPF_GATE_MIN_AUTHORITY_SOURCES=2

# Scoring thresholds
# KPF_SCORE_MIN_TOTAL=38.0
# KPF_SCORE_MIN_PAIN=7.0
# KPF_SCORE_MIN_SPEND=5.0
# KPF_SCORE_MIN_SOLO_FEASIBILITY=7.0
